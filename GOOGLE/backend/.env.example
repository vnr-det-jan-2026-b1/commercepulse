# Copy this file to .env and fill in your values
# Used by the FastAPI backend in local dev mode

# Set to "true" to skip Firebase JWT verification (local dev only)
CP_DEV_MODE=true

# Your GCP project
GCP_PROJECT=commercepulse-prod
GCP_REGION=asia-south1

# BigQuery datasets (must already exist in your project)
BQ_DATASET_RAW=cp_raw
BQ_DATASET_BRONZE=cp_bronze
BQ_DATASET_SILVER=cp_silver
BQ_DATASET_GOLD=cp_gold
BQ_DATASET_ML=cp_ml

# Leave as localhost if not using Redis locally
REDIS_URL=redis://localhost:6379

# Vertex AI / Gemini
VERTEX_LOCATION=asia-south1
GEMINI_MODEL=gemini-1.5-pro

# Pub/Sub topic for event collector
PUBSUB_EVENTS_TOPIC=commercepulse-events

# GCS bucket for uploads
GCS_UPLOAD_BUCKET=commercepulse-raw-uploads-prod
