# Groq LLM API (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Supabase — use the SERVICE ROLE key, NOT the anon/public key
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="eyJhbGciOiJIUzI1NiIs..."

# Backend API connection (for Orchestrator to fetch live analytics)
# Use http://backend:8010 inside Docker, http://127.0.0.1:8010 for local dev
BACKEND_API_URL="http://127.0.0.1:8010"
COMMERCE_API_KEY="your-backend-api-key"

# (optional) Supabase direct DB connection for migrations
SUPABASE_DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"
