# ── PostgreSQL (Supabase) ──
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Application ──
APP_ENV=production
API_KEY=your-secure-production-key
CORS_ORIGINS=["https://your-frontend-domain.com"]

# ── Redis (Celery) ──
REDIS_URL=redis://redis:6379/0

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMS=384

# ── AI Agents Integration ──
AI_AGENTS_URL=http://ai_agents:8001
GROQ_API_KEY=
